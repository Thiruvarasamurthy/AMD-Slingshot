# LemonadeFlow Environment Configuration

# Set to true to bypass actual localhost:8000 calls and return simulated <200ms NPU responses
# Set to false if you have AMD Lemonade Runtime running locally
USE_MOCK_LEMONADE=true

# Local AMD Lemonade Runtime Endpoint (Do not change unless proxying)
LEMONADE_API_BASE="http://localhost:8000/api/v1"

# Backend Orchestrator Port
PORT=8001

# OAuth Credentials (Required for Gmail Trigger node in production)
#GOOGLE_CLIENT_ID=your_client_id_here
#GOOGLE_CLIENT_SECRET=your_client_secret_here
